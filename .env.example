# Copy this file to `.env` and fill in real values locally.
# NEVER commit the real `.env` file.

# --- Gemini API key — used for script generation (LLM, 1 call per run) ---
# TTS is handled by edge-tts (free, no key needed) so quota usage is minimal.
# Free tier (1,500 req/day) is sufficient. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- AgenticQEAHub platform ---
AGENTICQEAHUB_BASE_URL=https://your-platform-host
HUB_EMAIL=
HUB_PASSWORD=

# --- Output ---
OUTPUT_DIR=./output

# --- Script review ---
# Set to true to auto-approve the narration script (skips the human review pause).
SKIP_REVIEW=false

# --- Corporate SSL proxy ---
# Python automatically uses the Windows certificate store (via the truststore
# package) so no manual action is needed on Cognizant machines.
# Only set DISABLE_SSL_VERIFY=true as a last resort if truststore cannot load.
DISABLE_SSL_VERIFY=false
