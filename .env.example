# Copy this file to `.env` and fill in real values locally.
# NEVER commit the real `.env` file.

# --- Gemini API key — covers both script generation (LLM) and TTS voice-over ---
# Personal key for prototyping; swap for an org key before wider rollout.
GEMINI_API_KEY=

# --- AgenticQEAHub platform ---
AGENTICQEAHUB_BASE_URL=https://your-platform-host
HUB_EMAIL=
HUB_PASSWORD=

# --- Output ---
OUTPUT_DIR=./output
